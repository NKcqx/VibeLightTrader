{
  "config": {"wide_screen_mode": true},
  "header": {
    "template": {{ color | tojson }},
    "title": {"tag": "plain_text", "content": {{ ((emoji ~ ' ' ~ code ~ ' · ' ~ severity)) | tojson }}}
  },
  "elements": [
    {
      "tag": "div",
      "text": {"tag": "lark_md", "content": {{ ('**$' ~ ('%.2f' | format(close)) ~ '**  ' ~ change_str) | tojson }}}
    }{% if diagnostics_md %},
    {"tag": "hr"},
    {
      "tag": "div",
      "text": {"tag": "lark_md", "content": {{ diagnostics_md | tojson }}}
    }{% endif %},
    {"tag": "hr"},
    {
      "tag": "div",
      "text": {"tag": "lark_md", "content": {{ ('**🚨 触发信号:**\n' ~ signals_md) | tojson }}}
    }{% if news_md %},
    {"tag": "hr"},
    {
      "tag": "div",
      "text": {"tag": "lark_md", "content": {{ ('**关键新闻:**\n' ~ news_md) | tojson }}}
    }{% endif %}{% if suggestion_md %},
    {"tag": "hr"},
    {
      "tag": "div",
      "text": {"tag": "lark_md", "content": {{ suggestion_md | tojson }}}
    }{% endif %},
    {"tag": "note", "elements": [{"tag": "plain_text", "content": {{ ts_str | tojson }}}]}
  ]
}
