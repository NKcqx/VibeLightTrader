# --------------------------------------------------------------------------
# Python build / cache
# --------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
.uv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.ipynb_checkpoints/

# --------------------------------------------------------------------------
# Local config & secrets — NEVER commit anything in this block
# --------------------------------------------------------------------------
# Real settings (with personal Lark open_id, possibly API keys via
# api_key_env). Public template lives in `config/settings.example.yaml`.
config/settings.yaml
config/settings.local.yaml
# Personal watchlist (real symbols/thresholds). Template:
# `config/watchlist.example.yaml`.
config/watchlist.yaml

# Generic secret / credential patterns
.env
.env.*
*.env
*.key
*.pem
*.p12
*.pfx
secrets/
.secrets/

# Cursor agent / IDE auth state — should live in $HOME, not here, but
# defend in depth in case it ever leaks into the workspace.
.cursor-agent/
.cursor/

# --------------------------------------------------------------------------
# Runtime data (root-level only; src/vibe_trader/data/ is source code)
# --------------------------------------------------------------------------
/data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.log
log/

# --------------------------------------------------------------------------
# Internal docs / planning notes — kept locally for ongoing iteration,
# not for public consumption (yet). README.md remains tracked.
# --------------------------------------------------------------------------
docs/

# --------------------------------------------------------------------------
# Per-symbol journals, snapshot PNGs, decision packets
# (*.log already covered above; no need to enumerate scheduler.log etc.)
# --------------------------------------------------------------------------
var/snapshots/*.png
!var/snapshots/.gitkeep
var/decisions/

# --------------------------------------------------------------------------
# Background process artifacts (nohup, pids)
# --------------------------------------------------------------------------
nohup.out
*.pid

# --------------------------------------------------------------------------
# Node (defensive — for MCP / frontend tooling that may show up later)
# --------------------------------------------------------------------------
node_modules/

# --------------------------------------------------------------------------
# OS / editor noise
# --------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
*.orig
*.rej
*.bak
Thumbs.db
